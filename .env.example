# Chase configuration — copy to .chase/.env and edit as needed
# Priority: environment variables > .chase/.env > defaults

# ============================================================
# LLM Provider — Global defaults (all agents inherit these)
# ============================================================

# API key and endpoint (OpenAI-compatible providers)
CHASE_LLM_API_KEY=your-api-key-here
CHASE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Default model for all agents
CHASE_MODEL=glm-4-plus

# ============================================================
# Per-Agent Overrides (take priority over global settings)
# Each agent can have its own api_key, base_url, and model.
# This lets you mix providers: e.g., GPT for planning,
# Claude for code generation and evaluation.
# ============================================================

# --- Example: GPT plans, Claude executes ---
# CHASE_PLANNER_API_KEY=sk-gpt-xxx
# CHASE_PLANNER_BASE_URL=https://api.openai.com/v1
# CHASE_PLANNER_MODEL=gpt-4o
#
# CHASE_GENERATOR_API_KEY=sk-claude-xxx
# CHASE_GENERATOR_BASE_URL=https://api.anthropic.com
# CHASE_GENERATOR_MODEL=claude-sonnet-4-20250514
#
# CHASE_EVALUATOR_API_KEY=sk-claude-xxx
# CHASE_EVALUATOR_BASE_URL=https://api.anthropic.com
# CHASE_EVALUATOR_MODEL=claude-sonnet-4-20250514

# --- Example: DeepSeek plans, ZhiPu executes ---
# CHASE_PLANNER_API_KEY=sk-deepseek-xxx
# CHASE_PLANNER_BASE_URL=https://api.deepseek.com/v1
# CHASE_PLANNER_MODEL=deepseek-chat
#
# CHASE_GENERATOR_MODEL=glm-4-plus
# CHASE_EVALUATOR_MODEL=glm-4-plus

# ============================================================
# Common provider endpoints
# ============================================================
# ZhiPu GLM:   https://open.bigmodel.cn/api/paas/v4
# DeepSeek:    https://api.deepseek.com/v1
# OpenAI:      https://api.openai.com/v1
# Anthropic:   https://api.anthropic.com
# Moonshot:    https://api.moonshot.cn/v1
# Qwen:        https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# Budget
# ============================================================
# CHASE_COST_LIMIT=10000.0

# ============================================================
# Sprint Tuning
# ============================================================
# CHASE_MAX_SPRINTS=50
# CHASE_MAX_RETRIES=3
# CHASE_EVAL_THRESHOLD=0.7
# CHASE_STALE_LIMIT=3

# ============================================================
# Playwright UI Testing
# ============================================================
# CHASE_PLAYWRIGHT=1
# CHASE_APP_URL=http://localhost:8000
